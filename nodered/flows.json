    {
        "id": "845be5779e774015",
        "type": "function",
        "z": "02b90a95fb708b01",
        "name": "Cervello ",
        "func": "// Recupero stati\nvar mode = context.get('mode') || 'DISARMED';\nvar alarmActive = flow.get('alarmActive') || false;\n\n// 1. NORMALIZZAZIONE (Telegram o Dashboard)\nvar input = msg.payload.toString().toUpperCase();\nif (input === \"DISARMED\" || input === \"TOTAL\" || input === \"NIGHT\" || input === \"/DISARMED\" || input === \"/TOTAL\" || input === \"/NIGHT\") {\n    // Rimuove la slash se presente (per comandi Telegram)\n    msg.payload = input.replace(\"/\", \"\");\n    msg.topic = \"ui/control/mode\";\n}\n\n// 2. RESET SISTEMA\nif (msg.topic === \"reset_allarme\" || msg.payload === \"/RESET\") {\n    flow.set('alarmActive', false);\n    global.set('pendingAlarm', null);\n    node.status({ fill: \"grey\", shape: \"dot\", text: \"Stato: PRONTO\" });\n    return [\n        { payload: \"SISTEMA PRONTO\" }, \n        { payload: \"disarmed\", topic: 'casa/caveau/cmd' }, \n        null, \n        { payload: \"✅ Sistema Resettato via Telegram\" }\n    ];\n}\n\n// 3. GESTIONE COMANDI (Cambio Modalità)\nif (msg.topic === 'ui/control/mode') {\n    var selectedMode = msg.payload.toUpperCase();\n    var cmdMQTT = selectedMode.toLowerCase();\n    \n    context.set('mode', selectedMode);\n    node.status({ fill: \"green\", shape: \"dot\", text: \"Modo: \" + selectedMode });\n\n    // Gestione Tenda\n    var tendaState = (selectedMode === \"DISARMED\") ? \"aperta\" : \"chiusa\";\n\n    return [\n        { payload: selectedMode }, // Verso Dashboard\n        { payload: cmdMQTT, topic: 'casa/caveau/cmd' }, // Verso ESP32\n        null, // Verso Sirena (null qui)\n        { payload: \"Settato modo: \" + selectedMode }, // Verso Telegram\n        { topic: \"casa/caveau/telemetry/tenda\", payload: tendaState } // Verso Tenda\n    ];\n}\n\n// 4. GESTIONE DATI DA HARDWARE (Allarmi)\nif (msg.topic === 'casa/caveau/status') {\n    var hwStatus = msg.payload.toString().toUpperCase();\n\n    if (hwStatus.startsWith(\"ALLARME\")) {\n        flow.set('alarmActive', true);\n        var sensorName = hwStatus.split(\"_\")[1] || \"GENERICO\";\n\n        node.status({ fill: \"red\", shape: \"dot\", text: \"🚨 ALLARME: \" + sensorName });\n        \n        return [\n            { payload: \"🚨 \" + sensorName + \"! 🚨\" }, \n            null,\n            { payload: 'SIREN', topic: 'home/buzzer' },\n            { payload: \"⚠️ ALLARME \" + sensorName + \" in modalità \" + mode }\n        ];\n    }\n    \n    // Stato normale da HW\n    context.set('mode', hwStatus);\n    node.status({ fill: \"blue\", shape: \"dot\", text: \"Stato HW: \" + hwStatus });\n    return [{ payload: hwStatus }, null, null, null];\n}\n\nreturn null;",
        "outputs": 4,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
