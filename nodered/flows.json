        "name": "",
        "order": 4,
        "width": 12,
        "height": 5,
        "format": "<div style=\"background:#1a1a1a; color:white; padding:10px; border-radius:5px; font-family:sans-serif;\">\n    <h3 style=\"color:#2ca591; margin-top:0;\">Storico Eventi</h3>\n    <table style=\"width:100%; text-align:left; border-collapse:collapse;\">\n        <thead>\n            <tr style=\"border-bottom:2px solid #2ca591; color:#2ca591;\">\n                <th style=\"padding:8px;\">Data</th>\n                <th style=\"padding:8px;\">Evento</th>\n                <th style=\"padding:8px;\">Sensore</th>\n                <th style=\"padding:8px;\">Tag</th>\n            </tr>\n        </thead>\n        <tbody>\n            <tr ng-repeat=\"r in msg.payload | limitTo:25\" style=\"border-bottom:1px solid #333;\">\n                <td style=\"padding:8px; font-size:0.9em;\">{{r.timestamp}}</td>\n                <td style=\"padding:8px;\">{{r.event}}</td>\n                <td style=\"padding:8px;\">{{r.sensor}}</td>\n                <td style=\"padding:8px;\">\n                    <span ng-style=\"{'color': r.criticality === 'PERICOLO' ? '#ff4d4d' : 'white'}\">\n                        {{r.criticality}}\n                    </span>\n                </td>\n            </tr>\n        </tbody>\n    </table>\n    <div ng-if=\"msg.payload.length === 0\" style=\"padding:20px; text-align:center; color:#666;\">\n        Nessun log presente nel database\n    </div>\n</div>",
