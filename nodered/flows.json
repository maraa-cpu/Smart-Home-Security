    {
        "id": "a991286fb6854db7",
        "type": "function",
        "z": "02b90a95fb708b01",
        "name": "formatta tab",
        "func": "// Recupero dello storico esistente o creazione di uno nuovo se è vuoto\nvar history = context.get('history') || [];\n\n// Creazione oggetto per la riga della tabella\nvar newEntry = {\n    \"Data/Ora\": new Date().toLocaleTimeString('it-IT'),\n    \"Evento\": msg.payload.payload,\n    \"Sensore\": msg.payload.sensor,\n    \"Modalità\": msg.payload.mode\n};\n\n// Aggiunta nuovo allarme in cima alla lista\nhistory.unshift(newEntry);\n\n// Solo gli ultimi 25 allarmi per non rallentare la pagina\nif (history.length > 25) {\n    history.pop();\n}\n\n// Salvataggio\ncontext.set('history', history);\n\n// Invio dell'array alla tabella\nmsg.payload = history;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
