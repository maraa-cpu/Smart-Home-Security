    {
        "id": "ce137e7d339d6193",
        "type": "function",
        "z": "ba047f83c3e4f540",
        "name": "Verifica Archiviazione",
        "func": "// Lock salvataggio\nvar alarm = global.get('pendingAlarm');\nvar tag = global.get('currentTag');\nvar isActive = flow.get('alarmActive') || false;\n\nif (isActive) {\n    return [null, { payload: \"⚠️ Errore: Disarma il sistema prima di archiviare!\" }];\n}\n\nif (!alarm) {\n    return [null, { payload: \"⚠️ Nessun allarme da archiviare.\" }];\n}\n\nif (!tag) {\n    return [null, { payload: \"⚠️ Seleziona una criticità prima di archiviare.\" }];\n}\n\n\n// Normalizza la modalità\nvar modeNorm = alarm.mode;\n\nif (modeNorm !== \"NIGHT\") {\n    modeNorm = \"TOTAL\";\n}\n\n// Messaggio PULITO verso DB\nreturn [{\n    _db: true,\n    event: alarm.event,\n    sensor: alarm.sensor,\n    mode: modeNorm,\n    criticality: tag\n}, null];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 310,
        "y": 320,
        "wires": [
