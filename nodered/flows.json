    {
        "id": "b6295be5ac1523e1",
        "type": "function",
        "z": "ba047f83c3e4f540",
        "name": "Dati tab",
        "func": "if (!msg._db) return null;\n\n// Local Italian Time\nvar dateStr = new Date().toLocaleString('it-IT', { \n    timeZone: 'Europe/Rome', \n    day: '2-digit', \n    month: '2-digit', \n    year: 'numeric', \n    hour: '2-digit', \n    minute: '2-digit', \n    second: '2-digit' \n});\n\nvar evento = \"MOVIMENTO RILEVATO\";\n\nvar parts = [\n    \"'\" + dateStr + \"'\",\n    \"'\" + evento  + \"'\",\n    \"'\" + (msg.sensor || \"\") + \"'\",\n    \"'\" + (msg.mode || \"\") + \"'\",\n    \"'\" + (msg.criticality || \"\") + \"'\"\n];\n\nmsg.topic = \"INSERT INTO logs (timestamp, event, sensor, mode, criticality) VALUES (\" + parts.join(\",\") + \")\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
